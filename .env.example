# Server-only. Copy to .env.local. Never commit real keys.
# Do not prefix these with VITE_ (that would expose them in the browser).
# Multiple GEMINI/GROQ/OPENROUTER/CEREBRAS slots: free Gemini is often high-demand, so Careero rotates keys and providers.

GEMINI_API_KEY_1=
GEMINI_API_KEY_2=
GEMINI_API_KEY_3=
GEMINI_API_KEY_4=
GEMINI_API_KEY_5=
DEEPSEEK_API_KEY_1=

GROQ_API_KEY_1=
GROQ_API_KEY_2=
CEREBRAS_API_KEY_1=
CEREBRAS_API_KEY_2=
OPENROUTER_API_KEY_1=
OPENROUTER_API_KEY_2=

# Grounded-first defaults: Groq → Gemini → OpenRouter → Cerebras → DeepSeek
GROQ_MODEL=groq/compound-mini
CEREBRAS_MODEL=gpt-oss-120b
OPENROUTER_MODEL=openai/gpt-oss-20b:free
OPENROUTER_SITE_URL=http://localhost:5173
OPENROUTER_APP_TITLE=Careero
GEMINI_MODEL=gemini-2.5-flash-lite
GEMINI_FALLBACK_MODEL=gemini-2.5-flash
DEEPSEEK_MODEL=deepseek-v4-flash
ENABLE_PAID_DEEPSEEK=true

KEY_COOLDOWN_MS=60000
PROVIDER_TIMEOUT_MS=75000
RECOMMENDATION_RATE_LIMIT_MAX=20
RECOMMENDATION_CACHE_TTL_SECONDS=86400
RECOMMENDATION_CACHE_MEMORY_ENTRIES=200
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
